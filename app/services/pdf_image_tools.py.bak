from pathlib import Path
import fitz

UPLOAD_DIR = Path('uploads')
UPLOAD_DIR.mkdir(exist_ok=True)


def pdf_to_images(pdf_path: str | Path, max_pages: int = 10, zoom: float = 2.0) -> list[str]:
    pdf_path = Path(pdf_path)
    out_dir = UPLOAD_DIR / 'pdf_pages' / pdf_path.stem
    out_dir.mkdir(parents=True, exist_ok=True)
    doc = fitz.open(str(pdf_path))
    images = []
    for page_i in range(min(len(doc), max_pages)):
        page = doc[page_i]
        pix = page.get_pixmap(matrix=fitz.Matrix(zoom, zoom), alpha=False)
        out = out_dir / f'page_{page_i + 1}.png'
        pix.save(str(out))
        images.append(str(out))
    return images

def select_relevant_pdf_pages(pdf_path: str):
    """
    Paprastas MVP: kol kas grąžina pirmus 3 puslapius.
    Vėliau čia galėsim daryti AI filtravimą.
    """
    try:
        from PyPDF2 import PdfReader

        reader = PdfReader(pdf_path)
        total_pages = len(reader.pages)

        selected = []
        for i in range(min(3, total_pages)):
            selected.append({
                "page_number": i,
                "reason": "default_first_pages"
            })

        return selected

    except Exception:
        return [{"page_number": 0, "reason": "fallback"}]
